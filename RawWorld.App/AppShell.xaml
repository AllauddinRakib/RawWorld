<?xml version="1.0" encoding="utf-8"?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:RawWorld.App.Pages"
       x:Class="RawWorld.App.AppShell"
       FlyoutBehavior="Flyout">

    <Shell.FlyoutHeader>
        <VerticalStackLayout BackgroundColor="#4CAF50" Padding="20" Spacing="4">
            <Label Text="Raw World" TextColor="White"
                   FontSize="20" FontAttributes="Bold"/>
            <Label Text="Authentic Juice Company"
                   TextColor="#E8F5E9" FontSize="12"/>
        </VerticalStackLayout>
    </Shell.FlyoutHeader>

    <Shell.FlyoutFooter>
        <VerticalStackLayout Padding="16">
            <Button Text="Logout"
                    BackgroundColor="#F44336"
                    TextColor="White"
                    CornerRadius="8"
                    Clicked="OnLogoutClicked"/>
        </VerticalStackLayout>
    </Shell.FlyoutFooter>

    <!-- Login / Register -->
    <ShellContent Title="Login" Route="login"
                  FlyoutItemIsVisible="False"
                  ContentTemplate="{DataTemplate pages:LoginPage}"/>
    <ShellContent Title="Register" Route="register"
                  FlyoutItemIsVisible="False"
                  ContentTemplate="{DataTemplate pages:RegisterPage}"/>

    <!-- Single TabBar for all users -->
    <TabBar x:Name="MainTabs">
        <ShellContent Title="Products" Route="products"
                      ContentTemplate="{DataTemplate pages:ProductListPage}"/>
        <ShellContent Title="Cart"     Route="cart"
                      ContentTemplate="{DataTemplate pages:CartPage}"/>
        <ShellContent Title="Orders"   Route="orders"
                      ContentTemplate="{DataTemplate pages:OrderListPage}"/>
        <ShellContent x:Name="AdminTab"
                      Title="Admin"   Route="admin"
                      IsVisible="False"
                      ContentTemplate="{DataTemplate pages:AdminPage}"/>
        <ShellContent x:Name="ManageTab"
                      Title="Manage"  Route="adminmanage"
                      IsVisible="False"
                      ContentTemplate="{DataTemplate pages:AdminProductPage}"/>
    </TabBar>
</Shell>