<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RawWorld.App.Pages.AdminProductPage"
             Title="Manage Products"
             BackgroundColor="#F5F5F5">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- Add Product Form -->
            <Frame Padding="16" CornerRadius="12"
                   HasShadow="True" BackgroundColor="White">
                <VerticalStackLayout Spacing="12">

                    <Label Text="➕ Add New Product"
                           FontSize="17" FontAttributes="Bold"/>
                    <BoxView HeightRequest="1" BackgroundColor="#E0E0E0"/>

                    <Entry Placeholder="Product Name"
                           Text="{Binding NewName}"/>

                    <Editor Placeholder="Description"
                            Text="{Binding NewDescription}"
                            HeightRequest="80"
                            AutoSize="TextChanges"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Entry Placeholder="Price (£)"
                               Text="{Binding NewPrice}"
                               Keyboard="Numeric"/>
                        <Entry Grid.Column="1"
                               Placeholder="Stock Qty"
                               Text="{Binding NewStock}"
                               Keyboard="Numeric"/>
                    </Grid>

                    <!-- Category Picker -->
                    <Frame Padding="8,4" CornerRadius="8"
                           BorderColor="#E0E0E0" HasShadow="False">
                        <Picker Title="Select Category"
                                SelectedItem="{Binding SelectedCategory}"
                                ItemsSource="{Binding Categories}"/>
                    </Frame>

                    <Button Text="Add Product"
                            Command="{Binding AddProductCommand}"
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            CornerRadius="8"
                            HeightRequest="46"
                            FontAttributes="Bold"/>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="#4CAF50"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Product List -->
            <Label Text="Current Products"
                   FontSize="17" FontAttributes="Bold"/>

            <CollectionView ItemsSource="{Binding Products}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,0,0,10" Padding="14"
                               CornerRadius="12" HasShadow="True"
                               BackgroundColor="White">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Name}"
                                           FontAttributes="Bold" FontSize="15"/>
                                    <Label Text="{Binding Category}"
                                           TextColor="Gray" FontSize="12"/>
                                    <Grid ColumnDefinitions="*,*">
                                        <Label Text="{Binding Price, StringFormat='£{0:F2}'}"
                                               TextColor="#4CAF50"
                                               FontAttributes="Bold"/>
                                        <Label Grid.Column="1"
                                               Text="{Binding Stock, StringFormat='Stock: {0}'}"
                                               TextColor="Gray" FontSize="12"/>
                                    </Grid>
                                </VerticalStackLayout>

                                <Button Grid.Column="1"
                                        Text="🗑"
                                        FontSize="20"
                                        BackgroundColor="#FFF0F0"
                                        TextColor="#F44336"
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        CornerRadius="22"
                                        VerticalOptions="Center"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                  Path=BindingContext.DeleteProductCommand}"
                                        CommandParameter="{Binding Id}"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         Spacing="8" Margin="0,20,0,0">
                        <Label Text="🛍" FontSize="40"
                               HorizontalOptions="Center"/>
                        <Label Text="No products yet"
                               FontSize="16" TextColor="Gray"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>