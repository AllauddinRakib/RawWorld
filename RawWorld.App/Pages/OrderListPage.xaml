<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RawWorld.App.Pages.OrderListPage"
             Title="My Orders"
             BackgroundColor="#F5F5F5">
	<CollectionView ItemsSource="{Binding Orders}" Margin="12">
		<CollectionView.ItemTemplate>
			<DataTemplate>
				<Frame Margin="0,0,0,10" Padding="16"
                       CornerRadius="12" HasShadow="True"
                       BackgroundColor="White">
					<Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">

						<Label Grid.Row="0" Grid.Column="0"
                               Text="{Binding Id, StringFormat='Order #{0}'}"
                               FontAttributes="Bold" FontSize="16"/>

						<Frame Grid.Row="0" Grid.Column="1"
                               Padding="8,4" CornerRadius="8"
                               BackgroundColor="#E8F5E9">
							<Label Text="{Binding Status}"
                                   TextColor="#4CAF50"
                                   FontSize="12" FontAttributes="Bold"/>
						</Frame>

						<Label Grid.Row="1" Grid.ColumnSpan="2"
                               Text="{Binding Total, StringFormat='Total: £{0:F2}'}"
                               FontSize="14" TextColor="Gray"
                               Margin="0,4,0,0"/>

						<Label Grid.Row="2" Grid.ColumnSpan="2"
                               Text="{Binding CreatedAt, StringFormat='Placed: {0:dd MMM yyyy}'}"
                               FontSize="12" TextColor="Gray"/>
					</Grid>
				</Frame>
			</DataTemplate>
		</CollectionView.ItemTemplate>

		<CollectionView.EmptyView>
			<VerticalStackLayout HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="12" Margin="0,80,0,0">
				<Label Text="📦" FontSize="60" HorizontalOptions="Center"/>
				<Label Text="No orders yet"
                       FontSize="18" FontAttributes="Bold"
                       HorizontalOptions="Center"/>
				<Label Text="Place your first order today"
                       FontSize="14" TextColor="Gray"
                       HorizontalOptions="Center"/>
			</VerticalStackLayout>
		</CollectionView.EmptyView>
	</CollectionView>
</ContentPage>