<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RawWorld.App.Pages.PaymentPage"
             Title="Payment"
             BackgroundColor="#F5F5F5">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- Order Summary -->
            <Frame Padding="16" CornerRadius="12"
                   HasShadow="True" BackgroundColor="White">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Order Summary"
                           FontSize="16" FontAttributes="Bold"/>
                    <BoxView HeightRequest="1" BackgroundColor="#E0E0E0"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Total Amount" FontSize="14" TextColor="Gray"/>
                        <Label Grid.Column="1"
                               Text="{Binding TotalAmount, StringFormat='£{0:F2}'}"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="#4CAF50"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Payment Method Selection -->
            <Label Text="Select Payment Method"
                   FontSize="16" FontAttributes="Bold"/>

            <!-- Card Payment -->
            <Frame Padding="16" CornerRadius="12"
                   HasShadow="True" BackgroundColor="White">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Text="💳" FontSize="24" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Credit / Debit Card"
                               FontSize="15" FontAttributes="Bold"
                               VerticalOptions="Center" Margin="10,0"/>
                        <RadioButton Grid.Column="2"
                                     IsChecked="{Binding IsCardSelected}"
                                     Value="Card"/>
                    </Grid>

                    <!-- Card Fields - only show when card selected -->
                    <VerticalStackLayout Spacing="10"
                                         IsVisible="{Binding IsCardSelected}">
                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0"/>
                        <Entry Placeholder="Card Number (16 digits)"
                               Text="{Binding CardNumber}"
                               Keyboard="Numeric"
                               MaxLength="16"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Entry Placeholder="MM/YY"
                                   Text="{Binding CardExpiry}"
                                   MaxLength="5"/>
                            <Entry Grid.Column="1"
                                   Placeholder="CVV"
                                   Text="{Binding CardCvv}"
                                   Keyboard="Numeric"
                                   IsPassword="True"
                                   MaxLength="3"/>
                        </Grid>
                        <Entry Placeholder="Cardholder Name"
                               Text="{Binding CardName}"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- bKash -->
            <Frame Padding="16" CornerRadius="12"
                   HasShadow="True" BackgroundColor="White">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Frame WidthRequest="32" HeightRequest="32"
                               CornerRadius="16" Padding="0"
                               BackgroundColor="#E2136E">
                            <Label Text="b" TextColor="White"
                                   FontAttributes="Bold" FontSize="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Frame>
                        <Label Grid.Column="1" Text="bKash"
                               FontSize="15" FontAttributes="Bold"
                               VerticalOptions="Center" Margin="10,0"/>
                        <RadioButton Grid.Column="2"
                                     IsChecked="{Binding IsBkashSelected}"
                                     Value="bKash"/>
                    </Grid>

                    <VerticalStackLayout Spacing="10"
                                         IsVisible="{Binding IsBkashSelected}">
                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0"/>
                        <Entry Placeholder="bKash Account Number"
                               Text="{Binding MobileNumber}"
                               Keyboard="Telephone"/>
                        <Label Text="You will receive a confirmation SMS"
                               FontSize="12" TextColor="Gray"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Nagad -->
            <Frame Padding="16" CornerRadius="12"
                   HasShadow="True" BackgroundColor="White">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Frame WidthRequest="32" HeightRequest="32"
                               CornerRadius="16" Padding="0"
                               BackgroundColor="#F7941D">
                            <Label Text="N" TextColor="White"
                                   FontAttributes="Bold" FontSize="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Frame>
                        <Label Grid.Column="1" Text="Nagad"
                               FontSize="15" FontAttributes="Bold"
                               VerticalOptions="Center" Margin="10,0"/>
                        <RadioButton Grid.Column="2"
                                     IsChecked="{Binding IsNagadSelected}"
                                     Value="Nagad"/>
                    </Grid>

                    <VerticalStackLayout Spacing="10"
                                         IsVisible="{Binding IsNagadSelected}">
                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0"/>
                        <Entry Placeholder="Nagad Account Number"
                               Text="{Binding MobileNumber}"
                               Keyboard="Telephone"/>
                        <Label Text="You will receive a confirmation SMS"
                               FontSize="12" TextColor="Gray"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Delivery Address -->
            <Frame Padding="16" CornerRadius="12"
                   HasShadow="True" BackgroundColor="White">
                <VerticalStackLayout Spacing="10">
                    <Label Text="📍 Delivery Address"
                           FontSize="15" FontAttributes="Bold"/>
                    <Editor Placeholder="Enter your full delivery address"
                            Text="{Binding Address}"
                            HeightRequest="80"
                            AutoSize="TextChanges"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Pay Button -->
            <Button Text="{Binding PayButtonText}"
                    Command="{Binding PayCommand}"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    CornerRadius="12"
                    FontSize="16"
                    FontAttributes="Bold"
                    HeightRequest="54"/>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#4CAF50"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>